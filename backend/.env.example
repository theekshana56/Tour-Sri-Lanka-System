# Copy to backend/.env and fill in your values (never commit .env)

# MongoDB Atlas — Database → Connect → Drivers
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tsldb?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/tsldb?retryWrites=true&w=majority

# JWT — use a random 256-bit secret in production
JWT_SECRET=tsl-super-secret-key-change-in-production-must-be-256-bits

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev
